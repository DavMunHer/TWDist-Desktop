{
  "name": "twdist-desktop",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "bun run electron:dev",
    "build": "ng build --base-href ./",
    "test": "ng test --watch=false",
    "test:watch": "ng test --watch",
    "electron:tsc": "tsc -p electron/tsconfig.json",
    "electron:serve": "wait-on tcp:4200 && cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k \"ng serve\" \"bun run electron:tsc && bun run electron:serve\"",
    "electron:build": "bun run build && bun run electron:tsc && electron-builder",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.8.2",
    "electron-builder": "^26.8.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-devkit/build-angular": "^20.3.20",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.18",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "jsdom": "^27.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.46.4",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.twdist.app",
    "productName": "TWDist - Desktop version",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/twdist-desktop/browser/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}